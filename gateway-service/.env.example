# Copy to .env and fill in with real paths from your WSL2 test-network.
# One .env per org -- Org1's gateway and Org2's gateway are separate
# running processes with separate identities, never shared.

MSP_ID=Org1MSP
ORG_LABEL=Org1 - Police

PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com
TLS_CERT_PATH=/home/s4f3ty/blockchain-privacy-preserving/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt
IDENTITY_CERT_PATH=/home/s4f3ty/blockchain-privacy-preserving/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/signcerts/Admin@org1.example.com-cert.pem
IDENTITY_KEY_PATH=/home/s4f3ty/blockchain-privacy-preserving/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/keystore/priv_sk

CHANNEL_NAME=channel1-2
CHAINCODE_NAME=evidence

IPFS_API_URL=http://127.0.0.1:5001
IPFS_POLL_INTERVAL_MS=5000

HTTP_PORT=4000
STATE_FILE_PATH=./data/gateway-state.json
